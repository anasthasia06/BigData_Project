global:
  scrape_interval: 5s
  evaluation_interval: 5s

remote_write:
  - url: https://prometheus-prod-55-prod-gb-south-1.grafana.net/api/prom/push
    basic_auth:
      username: "${GRAFANA_USER_ID}"
      password: "${GRAFANA_API_TOKEN}"

scrape_configs:
  - job_name: steam_api
    metrics_path: /metrics
    static_configs:
      - targets: ["host.docker.internal:8000"]
